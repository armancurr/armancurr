{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "es2024": true
  },
  "plugins": ["typescript", "import", "jsx-a11y", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "import/no-unassigned-import": "off"
  },
  "ignorePatterns": [".agents/**", ".oc/**", "dist/**", "node_modules/**"]
}
