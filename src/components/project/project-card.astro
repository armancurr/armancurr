---
import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { PhGithubLogo, PhGlobeSimple } from "phosphor-icons-astro";

export interface Props {
  project: {
    id: string;
    title: string;
    subtitle: string;
    description: string;
    technologies: string[];
    github?: string;
    demo?: string;
  };
}

const { project } = Astro.props;

function getProjectColor(tech: string): string {
  const projectMap: Record<string, string> = {
    Summarization: "bg-teal-950 border-teal-800 text-teal-300",
    Chatbot: "bg-teal-950 border-teal-800 text-teal-300",
    Research: "bg-teal-950 border-teal-800 text-teal-300",
    "Image Processing": "bg-lime-950 border-lime-800 text-lime-300",
    "Image Upscaling": "bg-lime-950 border-lime-800 text-lime-300",
    "Image Conversion": "bg-lime-950 border-lime-800 text-lime-300",
    "Command Line": "bg-indigo-950 border-indigo-800 text-indigo-300",
    Automation: "bg-indigo-950 border-indigo-800 text-indigo-300",
    "Food Recommendation": "bg-orange-950 border-orange-800 text-orange-300",
    Gamification: "bg-orange-950 border-orange-800 text-orange-300",
    "Personal Finance": "bg-orange-950 border-orange-800 text-orange-300",
    default: "bg-neutral-950 border-neutral-800 text-neutral-300",
  };
  return projectMap[tech] || projectMap["default"];
}
---

<Card
  className="overflow-hidden border-2 border-neutral-800 bg-neutral-950 transition-all duration-200 hover:border-neutral-700"
>
  <CardContent className="space-y-4 p-8">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-semibold text-neutral-200">
        {project.title} - <span class="text-sm font-medium text-neutral-400"
          >{project.subtitle}</span
        >
      </h1>
    </div>

    <div class="flex flex-wrap gap-2">
      {
        project.technologies.map((tech: string) => (
          <Badge
            variant="secondary"
            className={`flex items-center gap-2 rounded-md border-2 px-3 py-1.5 ${getProjectColor(tech)}`}
          >
            {tech}
          </Badge>
        ))
      }
    </div>

    <p class="text-md leading-relaxed text-neutral-400">
      {project.description}
    </p>

    <div class="flex w-full gap-3 pt-2">
      {
        project.github && (
          <a
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-1 items-center justify-center rounded-lg border-2 border-neutral-700 bg-neutral-900 px-4 py-3 font-medium text-neutral-200 transition-all duration-200 hover:border-neutral-600 hover:bg-neutral-800 hover:text-white"
          >
            <PhGithubLogo class="mr-2 h-4 w-4" />
            Source Code
          </a>
        )
      }
      {
        project.demo && (
          <a
            href={project.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-1 items-center justify-center rounded-lg border-2 border-neutral-600 bg-neutral-200 px-4 py-3 font-medium text-neutral-900 transition-all duration-200 hover:border-neutral-500 hover:bg-white hover:shadow-lg"
          >
            <PhGlobeSimple class="mr-2 h-4 w-4" />
            Live Demo
          </a>
        )
      }
    </div>
  </CardContent>
</Card>
