---
import { PhCirclesThree } from "phosphor-icons-astro";
---

<a
  href="https://arcun.site"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Open arcun.site"
  class="group block h-full w-full"
>
  <div
    class="flex h-full min-h-[240px] transform cursor-default cursor-pointer items-center justify-center rounded-xl border border-neutral-900 bg-black transition-all duration-200 active:scale-95 sm:min-h-[280px] md:min-h-[320px]"
  >
    <PhCirclesThree
      size={48}
      weight="fill"
      class="text-neutral-400 transition-colors duration-200 group-hover:text-neutral-300"
    />
  </div>
</a>
