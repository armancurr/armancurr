---
import {
  PhGithubLogo,
  PhLinkedinLogo,
  PhTwitterLogo,
  PhEnvelopeOpen,
} from "phosphor-icons-astro";

import connectData from "@/data/connect.json";
const iconMap = {
  GitHub: PhGithubLogo,
  LinkedIn: PhLinkedinLogo,
  Twitter: PhTwitterLogo,
  Email: PhEnvelopeOpen,
};
---

<div
  class="rounded-xl border-3 border-neutral-800 bg-neutral-950 transition-colors duration-200 hover:border-neutral-700"
>
  <div class="p-4">
    <div
      class="grid grid-cols-2 gap-2 px-3 sm:flex sm:flex-col sm:items-center sm:justify-center sm:gap-0 sm:space-y-2"
    >
      {
        connectData.socialLinks.map((link) => {
          const IconComponent = iconMap[link.name as keyof typeof iconMap];
          return (
            <a
              href={link.url}
              target={link.name !== "Email" ? "_blank" : undefined}
              rel={link.name !== "Email" ? "noopener noreferrer" : undefined}
              class="flex w-full flex-col items-center justify-center rounded-lg p-3 text-neutral-400 transition-colors duration-200 hover:text-neutral-200"
              aria-label={link.ariaLabel}
            >
              <div class="mb-2 flex items-center justify-center rounded-full border-3 border-dashed border-neutral-700 p-2">
                <IconComponent size={24} weight="fill" class={link.iconColor} />
              </div>
              <span class="text-center text-sm leading-tight">
                {link.description}
              </span>
            </a>
          );
        })
      }
    </div>
  </div>
</div>
