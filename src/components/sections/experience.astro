---
import { Card, CardHeader, CardTitle, CardContent } from "../ui/card";
import experienceData from "../../data/experience.json";

interface Experience {
  id: string;
  position: string;
  company: string;
  duration: string;
  description: string;
  technologies: string[];
}
---

<section class="py-24 lg:py-32">
  <div class="container px-4 md:px-6">
    <div
      class="flex flex-col items-center justify-center space-y-4 text-center"
    >
      <div class="space-y-2">
        <h2 class="text-3xl font-bold tracking-tighter md:text-4xl">
          Experience
        </h2>
        <p class="text-muted-foreground max-w-[900px] md:text-xl">
          My professional journey and key accomplishments
        </p>
      </div>
    </div>

    <div class="mx-auto grid max-w-5xl items-center gap-6 py-12 lg:gap-12">
      {
        experienceData.map((exp: Experience) => (
          <Card key={exp.id} className="relative" client:load>
            <CardHeader>
              <div class="flex items-start justify-between">
                <div>
                  <CardTitle className="text-xl">{exp.position}</CardTitle>
                  <p class="text-primary text-lg font-medium">{exp.company}</p>
                  <p class="text-muted-foreground text-sm">{exp.duration}</p>
                </div>
              </div>
            </CardHeader>
            <CardContent>
              <p class="text-muted-foreground mb-4">{exp.description}</p>
              <div class="flex flex-wrap gap-2">
                {exp.technologies.map((tech: string) => (
                  <span class="border-border inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold">
                    {tech}
                  </span>
                ))}
              </div>
            </CardContent>
          </Card>
        ))
      }
    </div>
  </div>
</section>
