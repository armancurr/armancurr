---
import testimonialsData from "../../data/testimonials.json";

interface Testimonial {
    id: string;
    name: string;
    position: string;
    company: string;
    avatar: string;
    content: string;
}
---

<section class="px-6 py-12 border-t border-neutral-700/50">
    <div class="space-y-8">
        <h2 class="text-xl font-semibold text-neutral-100 text-center">
            TESTIMONIALS
        </h2>

        <div class="space-y-6">
            {testimonialsData.map((testimonial: Testimonial) => (
                <div class="bg-neutral-700/30 border border-neutral-600/30 rounded-xl p-6 space-y-4 hover:bg-neutral-700/50 hover:border-neutral-600/50 transition-all duration-300">
                    <!-- Testimonial Content -->
                    <blockquote class="text-sm text-neutral-300 italic leading-relaxed">
                        "{testimonial.content}"
                    </blockquote>
                    
                    <!-- Author Info -->
                    <div class="flex items-center space-x-3 pt-2">
                        <div class="w-10 h-10 bg-neutral-600 rounded-full flex items-center justify-center">
                            <span class="text-xs font-medium text-neutral-300">
                                {testimonial.name.split(' ').map(n => n[0]).join('')}
                            </span>
                        </div>
                        <div class="space-y-0">
                            <div class="text-sm font-medium text-neutral-200">
                                {testimonial.name}
                            </div>
                            <div class="text-xs text-neutral-400">
                                {testimonial.position} at {testimonial.company}
                            </div>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>