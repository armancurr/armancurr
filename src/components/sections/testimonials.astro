---
import testimonialsData from "../../data/testimonials.json";

interface Testimonial {
  id: string;
  name: string;
  position: string;
  company: string;
  content: string;
  linkedinUrl: string;
  companyLinkedinUrl: string;
}

const getInitials = (name: string) => {
  return name
    .split(" ")
    .map((n) => n[0])
    .join("")
    .slice(0, 2);
};

const firstTwoTestimonials = testimonialsData.slice(0, 2);
---

<div
  class="col-span-1 rounded-lg border-2 border-neutral-800 bg-neutral-950 transition-colors duration-200 hover:border-neutral-700 md:col-span-2 lg:col-span-2 cursor-default"
>
  <div class="p-6">
    <div class="space-y-6">
      {
        firstTwoTestimonials.map((testimonial: Testimonial, index: number) => (
          <div class="space-y-3 rounded-lg border border-neutral-800/50 p-4 transition-all duration-200 hover:bg-neutral-900/30">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-md border-2 border-neutral-700 bg-neutral-800">
                <span class="text-xs font-medium text-neutral-300">
                  {getInitials(testimonial.name)}
                </span>
              </div>
              <div class="flex-1">
                <a
                  href={testimonial.linkedinUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block text-sm font-medium text-neutral-200 transition-colors hover:text-neutral-100"
                >
                  {testimonial.name}
                </a>
                <div class="text-xs text-neutral-500">
                  {testimonial.position} at{" "}
                  <a
                    href={testimonial.companyLinkedinUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-neutral-400 transition-colors hover:text-neutral-300"
                  >
                    {testimonial.company}
                  </a>
                </div>
              </div>
            </div>
            <blockquote class="pl-0 text-md leading-relaxed text-neutral-200">
              "{testimonial.content}"
            </blockquote>
          </div>
        ))
      }
    </div>
  </div>
</div>
