---
import "../../global.css";
import { getCollection } from 'astro:content';
import { PhArrowUpRight, PhCircle } from "phosphor-icons-astro";

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>blog - thoughts that shouldn't exist</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Funnel+Sans&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-[var(--background)] min-h-screen flex flex-col items-center justify-start p-8"
  >
    <div class="flex flex-col max-w-2xl w-full gap-12 mt-12">
      <section
        class="transition-all duration-700 ease-out will-change-transform opacity-0 translate-y-3"
      >
        <div class="flex items-baseline gap-3">
          <h1 class="text-[var(--text-secondary)] text-2xl font-medium">
            <span class="text-[var(--text-primary)] text-md">~</span>
            <span class="text-[var(--text-accent)] text-md ml-1 mr-3">❯</span>
            blog
          </h1>
          <span class="text-[var(--text-muted)] text-sm italic">
            (thoughts unauthorized by reality)
          </span>
        </div>
        <p class="text-[var(--text-secondary)] text-lg mt-2">
          words arranged in patterns that defy their own existence
        </p>
      </section>

      <section
        class="flex flex-col gap-8 transition-all duration-700 ease-out will-change-transform opacity-0 translate-y-3"
      >
        {
          sortedPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group block">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-1">
                    <PhCircle 
                      size={8} 
                      weight="fill" 
                      class="text-[var(--text-accent)] animate-pulse"
                    />
                    <h2 class="text-[var(--text-secondary)] group-hover:text-[var(--text-primary)] text-xl font-medium transition-colors duration-200">
                      {post.data.title}
                    </h2>
                  </div>
                  <p class="text-[var(--text-muted)] text-sm ml-5">
                    {post.data.description || "no description because descriptions are lies"}
                  </p>
                  <div class="flex items-center gap-2 ml-5 mt-2">
                    <span class="text-[var(--text-muted)] text-xs">
                      {new Date(post.data.date).toLocaleDateString('en-US', { 
                        year: 'numeric', 
                        month: 'short', 
                        day: 'numeric' 
                      })}
                    </span>
                    <span class="text-[var(--text-muted)] text-xs">•</span>
                    <span class="text-[var(--text-muted)] text-xs italic">
                      (time is a construct)
                    </span>
                  </div>
                </div>
                <div class="p-2 -m-2 group-hover:bg-[var(--background-hover)] rounded transition-colors duration-200">
                  <PhArrowUpRight
                    size={18}
                    weight="bold"
                    class="text-[var(--text-secondary)] transform group-hover:rotate-45 transition-transform duration-300"
                  />
                </div>
              </div>
            </a>
          ))
        }
      </section>

      <section
        class="flex items-center gap-2 text-sm text-[var(--text-muted)] transition-all duration-700 ease-out will-change-transform opacity-0 translate-y-3"
      >
        <a
          href="/"
          class="hover:text-[var(--text-primary)] transition-colors duration-200"
        >
          ← return to the void
        </a>
      </section>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const sections = document.querySelectorAll("section");
        const reduce = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        if (reduce) {
          sections.forEach((el) => {
            el.classList.remove("opacity-0", "translate-y-3");
            el.classList.add("opacity-100", "translate-y-0");
          });
          return;
        }
        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const el = entry.target;
                el.classList.remove("opacity-0", "translate-y-3");
                el.classList.add("opacity-100", "translate-y-0");
                obs.unobserve(el);
              }
            });
          },
          { threshold: 0.12 },
        );
        sections.forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>
