---
import Analytics from '@vercel/analytics/astro';
import "../global.css";
import { PhArrowUpRight } from "phosphor-icons-astro";

const projects = [
  { name: "pazman", url: "https://github.com/armancurr/pazman.git", description: "quickly fetch your passwords from your terminal", type: "cli" },
  { name: "openmerge", url: "https://github.com/armancurr/openmerge.git", description: "automate your pull requests while never leaving the terminal", type: "cli" },
  { name: "vizum", url: "https://github.com/armancurr/vizum.git", description: "image utility tool to compress, convert, and resize images", type: "web" },
  { name: "coinsavor", url: "https://github.com/armancurr/coinsavor.git", description: "it helps you save money by giving you meal plans that you should not ignore", type: "web" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>studio - arman's creative space</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <Analytics />
  </head>
  <body class="bg-[var(--background)] min-h-screen flex flex-col items-center justify-center p-8 relative overflow-hidden">
    <canvas id="studio-bg" class="absolute inset-0 pointer-events-none"></canvas>

    <nav class="absolute top-8 left-8 z-10">
      <a
        href="/"
        class="flex items-center gap-2 text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors duration-200"
      >
        <PhArrowUpRight size={18} weight="bold" class="rotate-180" />
        back to portfolio
      </a>
    </nav>

    <main id="studio-container" class="flex flex-col w-full max-w-4xl z-10 gap-8">
      <section class="transition-all duration-700 ease-out opacity-0 translate-y-3">
        <h1 class="text-[var(--text-secondary)] text-2xl font-medium">
          <span class="text-[var(--text-primary)] text-md ml-1">~</span>
          <span class="text-[var(--text-accent)] text-md ml-1 mr-3">❯</span>
          studio
        </h1>
        <p class="text-[var(--text-muted)] text-lg">
          an interactive showcase • click nodes to open projects • press <span class="text-[var(--text-accent)]">space</span> to shuffle
        </p>
      </section>

      <section class="transition-all duration-700 ease-out opacity-0 translate-y-3">
        <div class="bg-[#0f0f23] border border-[#2a2a4e] rounded-lg p-6">
          <div class="flex gap-6 items-center mb-4">
            <div id="controls" class="flex gap-2 items-center">
              <button id="shuffle-btn" class="px-3 py-1 rounded bg-[var(--background-hover)] text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors duration-150">shuffle</button>
              <button id="toggle-btn" class="px-3 py-1 rounded bg-[var(--background-hover)] text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors duration-150">pause</button>
              <span class="ml-2 text-[var(--text-muted)] text-sm">active: <span id="active-node" class="text-[var(--text-accent)]">none</span></span>
            </div>
            <div class="ml-auto text-[var(--text-muted)] text-sm">nodes: <span id="node-count" class="text-[var(--text-accent)]">0</span></div>
          </div>

          <div class="relative">
            <canvas id="studio-canvas" class="w-full h-[480px] rounded-lg bg-[#1a1a2e] border border-[#2a2a4e]"></canvas>
            <div id="tooltip" class="absolute z-20 pointer-events-none px-3 py-2 rounded bg-[#0f0f23] border border-[#2a2a4e] text-[var(--text-muted)] text-sm hidden"></div>
          </div>

          <div id="list" class="mt-4 flex gap-4 flex-wrap text-[var(--text-muted)]">
            {
              projects.map((p) => (
                <a href={p.url} target="_blank" class="p-2 -m-2 hover:bg-[var(--background-hover)] rounded transition-colors duration-200">
                  {p.name}
                </a>
              ))
            }
          </div>
        </div>
      </section>
    </main>

    <script>
      class ParticleSystem {
        constructor(canvas) {
          this.canvas = canvas;
          this.ctx = canvas.getContext('2d');
          this.particles = [];
          this.resize();
          window.addEventListener('resize', () => this.resize());
        }
        resize() {
          this.canvas.width = window.innerWidth * devicePixelRatio;
          this.canvas.height = window.innerHeight * devicePixelRatio;
          this.canvas.style.width = window.innerWidth + 'px';
          this.canvas.style.height = window.innerHeight + 'px';
          this.ctx.scale(devicePixelRatio, devicePixelRatio);
        }
        createParticle(x, y, color = 'var(--text-accent)') {
          return {
            x,
            y,
            vx: (Math.random() - 0.5) * 1.5,
            vy: (Math.random() - 0.5) * 1.5,
            size: Math.random() * 2 + 0.5,
            color,
            life: 1.0,
            decay: Math.random() * 0.02 + 0.005
          };
        }
        addBurst(x, y, count = 10) {
          for (let i = 0; i < count; i++) this.particles.push(this.createParticle(x, y));
        }
        update() {
          this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
          this.particles = this.particles.filter(p => {
            p.x += p.vx;
            p.y += p.vy;
            p.life -= p.decay;
            if (p.life > 0) {
              this.ctx.globalAlpha = p.life;
              this.ctx.fillStyle = p.color;
              this.ctx.beginPath();
              this.ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
              this.ctx.fill();
              return true;
            }
            return false;
          });
        }
        animate() {
          this.update();
          requestAnimationFrame(() => this.animate());
        }
      }

      class Studio {
        constructor({ projects }) {
          this.canvas = document.getElementById('studio-canvas');
          this.bgCanvas = document.getElementById('studio-bg');
          this.ctx = this.canvas.getContext('2d');
          this.bgCtx = this.bgCanvas.getContext('2d');
          this.projects = projects;
          this.nodes = [];
          this.running = true;
          this.center = { x: 0, y: 0 };
          this.tooltip = document.getElementById('tooltip');
          this.activeNodeEl = document.getElementById('active-node');
          this.nodeCountEl = document.getElementById('node-count');
          this.shuffleBtn = document.getElementById('shuffle-btn');
          this.toggleBtn = document.getElementById('toggle-btn');
          this.particleSystem = new ParticleSystem(this.bgCanvas);
          this.init();
        }
        init() {
          this.resize();
          window.addEventListener('resize', () => this.resize());
          this.createNodes();
          this.bindEvents();
          this.draw();
          this.particleSystem.animate();
        }
        resize() {
          this.canvas.width = this.canvas.clientWidth * devicePixelRatio;
          this.canvas.height = this.canvas.clientHeight * devicePixelRatio;
          this.canvas.style.width = this.canvas.clientWidth + 'px';
          this.canvas.style.height = this.canvas.clientHeight + 'px';
          this.ctx.scale(devicePixelRatio, devicePixelRatio);
          this.bgCanvas.width = window.innerWidth * devicePixelRatio;
          this.bgCanvas.height = window.innerHeight * devicePixelRatio;
          this.bgCanvas.style.width = window.innerWidth + 'px';
          this.bgCanvas.style.height = window.innerHeight + 'px';
          this.bgCtx.scale(devicePixelRatio, devicePixelRatio);
          const rect = this.canvas.getBoundingClientRect();
          this.center = { x: rect.width / 2, y: rect.height / 2 };
        }
        createNodes() {
          const rect = this.canvas.getBoundingClientRect();
          const count = this.projects.length;
          const radius = Math.min(rect.width, rect.height) / 3.2;
          this.nodes = this.projects.map((p, i) => {
            const angle = (i / count) * Math.PI * 2;
            const x = this.center.x + Math.cos(angle) * radius;
            const y = this.center.y + Math.sin(angle) * radius;
            return {
              id: i,
              ...p,
              angle,
              radius,
              x,
              y,
              r: 22,
              vx: 0,
              vy: 0,
              color: 'var(--text-accent)'
            };
          });
          this.nodeCountEl.textContent = this.nodes.length;
        }
        drawNodes() {
          const ctx = this.ctx;
          ctx.clearRect(0, 0, this.canvas.clientWidth, this.canvas.clientHeight);
          this.nodes.forEach(node => {
            ctx.beginPath();
            ctx.fillStyle = node.color;
            ctx.globalAlpha = 0.85;
            ctx.arc(node.x, node.y, node.r, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = 'var(--text-secondary)';
            ctx.font = '12px "Public Sans", sans-serif';
            ctx.textAlign = 'center';
            ctx.fillText(node.name, node.x, node.y + node.r + 14);
          });
        }
        tick(dt) {
          this.nodes.forEach((n, i) => {
            n.angle += (0.002 + i * 0.0001) * (this.running ? 1 : 0);
            const radius = n.radius + Math.sin(Date.now() / 3000 + i) * 6;
            const x = this.center.x + Math.cos(n.angle) * radius;
            const y = this.center.y + Math.sin(n.angle) * radius;
            n.x += (x - n.x) * 0.08;
            n.y += (y - n.y) * 0.08;
          });
        }
        drawConnections() {
          const ctx = this.ctx;
          ctx.beginPath();
           ctx.strokeStyle = 'rgba(157,132,183,0.08)';
          ctx.lineWidth = 1;
          for (let i = 0; i < this.nodes.length; i++) {
            for (let j = i + 1; j < this.nodes.length; j++) {
              const a = this.nodes[i];
              const b = this.nodes[j];
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
            }
          }
          ctx.stroke();
        }
        bindEvents() {
          this.canvas.addEventListener('mousemove', (e) => this.handleMouseMove(e));
          this.canvas.addEventListener('click', (e) => this.handleClick(e));
          this.shuffleBtn.addEventListener('click', () => this.shuffle());
          this.toggleBtn.addEventListener('click', () => this.toggle());
          document.addEventListener('keydown', (e) => {
            if (e.code === 'Space') {
              e.preventDefault();
              this.shuffle();
            }
          });
        }
        shuffle() {
          this.nodes.forEach(n => { n.angle = Math.random() * Math.PI * 2; });
          const rect = this.canvas.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          this.nodes.forEach(n => this.particleSystem.addBurst(cx + (n.x - this.center.x), cy + (n.y - this.center.y), 12));
        }
        toggle() {
          this.running = !this.running;
          this.toggleBtn.textContent = this.running ? 'pause' : 'play';
        }
        handleMouseMove(e) {
          const rect = this.canvas.getBoundingClientRect();
          const mx = e.clientX - rect.left;
          const my = e.clientY - rect.top;
          const hovered = this.nodes.find(n => Math.hypot(n.x - mx, n.y - my) < n.r + 8);
          if (hovered) {
            this.tooltip.style.left = mx + 12 + 'px';
            this.tooltip.style.top = my + 12 + 'px';
            this.tooltip.innerHTML = `${hovered.name} <span class='text-[var(--text-muted)] text-xs block'>${hovered.description}</span>`;
            this.tooltip.classList.remove('hidden');
            this.activeNodeEl.textContent = hovered.name;
          } else {
            this.tooltip.classList.add('hidden');
            this.activeNodeEl.textContent = 'none';
          }
        }
        handleClick(e) {
          const rect = this.canvas.getBoundingClientRect();
          const mx = e.clientX - rect.left;
          const my = e.clientY - rect.top;
          const clicked = this.nodes.find(n => Math.hypot(n.x - mx, n.y - my) < n.r + 8);
          if (clicked) {
            window.open(clicked.url, '_blank');
            const cx = e.clientX;
            const cy = e.clientY;
            this.particleSystem.addBurst(cx, cy, 25);
          }
        }
        drawBackground() {
          const ctx = this.bgCtx;
          ctx.clearRect(0, 0, this.bgCanvas.width, this.bgCanvas.height);
           const grad = ctx.createLinearGradient(0, 0, this.bgCanvas.width, this.bgCanvas.height);
           grad.addColorStop(0, 'rgba(26,26,46,0.3)');
           grad.addColorStop(1, 'rgba(42,42,78,0.3)');
          ctx.fillStyle = grad;
          ctx.fillRect(0, 0, this.bgCanvas.width, this.bgCanvas.height);
        }
        draw(now) {
          if (!this.last) this.last = now;
          const dt = now - this.last;
          this.last = now;
          this.tick(dt);
          this.drawBackground();
          this.drawConnections();
          this.drawNodes();
          requestAnimationFrame((n) => this.draw(n));
        }
      }

      document.addEventListener('DOMContentLoaded', () => {
        new Studio({ projects: JSON.parse(JSON.stringify({ projects: [] })), projects: [
          { name: 'pazman', url: 'https://github.com/armancurr/pazman.git', description: 'quickly fetch your passwords from your terminal' },
          { name: 'openmerge', url: 'https://github.com/armancurr/openmerge.git', description: 'automate your pull requests while never leaving the terminal' },
          { name: 'vizum', url: 'https://github.com/armancurr/vizum.git', description: 'image utility tool to compress, convert, and resize images' },
          { name: 'coinsavor', url: 'https://github.com/armancurr/coinsavor.git', description: 'it helps you save money by giving you meal plans that you should not ignore' }
        ]});
      });
    </script>
  </body>
</html>
